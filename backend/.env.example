# Copy to .env and fill in real values. Never commit .env.

LLM_PROVIDER=groq

# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Alternative provider (set LLM_PROVIDER=google to use)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash

# Get a free key at https://tavily.com (1000 searches/month free)
# Recommended: more reliable than duckduckgo-search on some networks.
TAVILY_API_KEY=

LLM_TEMPERATURE=0.2
LLM_MAX_RETRIES=3

MAX_RESEARCH_RETRIES=1
MAX_SEARCH_RESULTS_PER_QUERY=4

# Postgres connection string for application data
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/zylabs

# Optional separate Postgres connection string for LangGraph checkpoints.
# If unset, checkpoints reuse DATABASE_URL.
CHECKPOINT_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/zylabs_checkpoints

LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
